{
  "name": "educational-text-editor",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "npm run dev -w @myapp/client",
    "dev:server": "npm run dev -w @myapp/server",
    "build": "npm run build -w @myapp/client",
    "test": "npm run test --workspaces --if-present",
    "test:run": "npm run test:run --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
